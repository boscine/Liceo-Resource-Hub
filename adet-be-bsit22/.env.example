# Liceo Resource Hub - Backend Configuration
# Copy this to .env and update values for your local machine

# Port the Hono server runs on
PORT=3000

# Database Connection String
# Replace 'root' and '12345' with your MySQL username and password
# Replace 'localhost:3306' with your MySQL host and port
# Replace 'adet_bsitdb22' with your database name
DATABASE_URL="mysql://root:12345@localhost:3306/adet_bsitdb22"

# JWT Secret for authentication tokens
# In production, use a long, random string
JWT_SECRET="liceo_academic_curator_secret_2026_key"

# (Optional) Email Service Config - Future use
# EMAIL_HOST="smtp.gmail.com"
# EMAIL_USER="your-email@gmail.com"
# EMAIL_PASS="your-app-password"
